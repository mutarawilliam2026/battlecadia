# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template of variable names SHOULD be committed (no real values in it)
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent skills
# Generated, machine-specific symlinks into .agents/skills (absolute paths — break on other machines)
.claude/skills/
# Bundled type-definition trees: huge, with deeply nested paths that exceed the Windows
# 260-char limit and break `git checkout`. Re-fetch skills with `npx skills add` instead.
.agents/skills/**/assets/types/
