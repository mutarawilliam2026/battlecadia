# Battlecadia environment variables — TEMPLATE
#
# Copy this file to `.env.local` and fill in the real values:
#   cp .env.local.example .env.local
#
# `.env.local` is gitignored and must NEVER be committed. Only variables prefixed
# with NEXT_PUBLIC_ are exposed to the browser — keep every secret un-prefixed.

# --- Google Gemini (server-side only) -------------------------------------
# Used by the AI search step that returns candidate items for a battle.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Channel3 (server-side only) ------------------------------------------
# Universal product catalog — powers product search / the candidate items that
# battle in an arena. Get a free key at https://trychannel3.com
CHANNEL3_API_KEY=

# --- Supabase (backend: database + auth) ----------------------------------
# Project URL and the publishable/anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret (service-role) key — FULL ADMIN ACCESS, bypasses RLS.
# Server-side only. Never expose to the browser; never give it a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=
